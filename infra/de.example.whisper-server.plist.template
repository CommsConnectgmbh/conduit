<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>de.example.whisper-server</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/whisper-server</string>
    <string>-m</string>
    <string>REPLACE_WITH_WHISPER_DIR/models/ggml-medium-q5_0.bin</string>
    <string>-l</string>
    <string>de</string>
    <string>--port</string>
    <string>8088</string>
    <string>--host</string>
    <string>127.0.0.1</string>
    <string>--convert</string>
    <string>--tmp-dir</string>
    <string>/tmp</string>
    <string>-nt</string>
    <string>-t</string>
    <string>6</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>REPLACE_WITH_HOME</string>
  </dict>
  <key>WorkingDirectory</key>
  <string>/tmp</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>
  <key>ThrottleInterval</key>
  <integer>10</integer>
  <key>StandardOutPath</key>
  <string>REPLACE_WITH_HOME/Library/Logs/llm-bridge/whisper-server.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>REPLACE_WITH_HOME/Library/Logs/llm-bridge/whisper-server.stderr.log</string>
  <key>ProcessType</key>
  <string>Interactive</string>
  <key>Nice</key>
  <integer>-5</integer>
</dict>
</plist>
