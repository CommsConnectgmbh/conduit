# Must match AUTH/BRIDGE secrets used by the web side
BRIDGE_SECRET=replace-with-random-32-bytes-hex

# Local bind — MUST stay 127.0.0.1. The Cloudflare tunnel terminates TLS and
# forwards to loopback. NEVER set this to 0.0.0.0: that exposes the bridge to
# the LAN, where a valid 5-min token or the BRIDGE_SECRET is enough for full
# bypassPermissions host access.
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8787

# Optional: only accept WS/HTTP whose Host header is in this comma-separated
# allowlist (DNS-rebinding protection). Leave empty to skip the check.
# Example: BRIDGE_ALLOWED_HOSTS=conduit.rainerroloff.de,jarvis.rainerroloff.de
BRIDGE_ALLOWED_HOSTS=

# Path to your local `claude` CLI binary
CLAUDE_BIN=/Users/yourname/.local/bin/claude

# Default cwd that claude spawns in (use a project root with skills/memory)
CLAUDE_CWD=/Users/yourname/code

# SECURITY: hard allowlist of roots that @-mention file search and per-session
# cwd may touch. Colon-separated absolute paths. Scope this to concrete project
# roots — NEVER homedir() — so an allowlisted user cannot enumerate or read the
# whole filesystem. Secret files (.env*, *.pem, *.key, *.p8, id_rsa…) are always
# excluded even inside these roots. Defaults to CLAUDE_CWD if unset.
FILE_SEARCH_ROOTS=/Users/yourname/code

# Claude model id (any current Anthropic model)
CLAUDE_MODEL=claude-opus-4-7

# Where bridge writes its rolling logs
LOG_DIR=/Users/yourname/Library/Logs/conduit-bridge
