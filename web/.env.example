# JWT signing — generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-random-32-bytes-hex
# Shared with bridge .env.local
BRIDGE_SECRET=replace-with-random-32-bytes-hex

# Resend.com API key for OTP mail delivery
RESEND_API_KEY=re_xxxxxxxxxxxx

# Comma-separated allowlist (only these emails can request login codes)
ALLOWED_EMAILS=you@example.com

# Public URLs once deployed
APP_URL=https://conduit.example.com
BRIDGE_URL=wss://bridge.example.com

# Sender identity for the OTP mail
FROM_EMAIL=conduit@example.com
FROM_NAME=Conduit
